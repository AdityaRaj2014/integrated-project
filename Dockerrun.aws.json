{
  "AWSEBDockerrunVersion": "3",
  "containerDefinitions": [
    {
      "name": "healthcare-backend",
      "image": "adityaraj2104/healthcare-backend:latest",
      "essential": true,
      "memory": 512,
      "restartPolicy": {
        "name": "always"
      },
      "environment": [
        {
          "name": "GROQ_API_KEY",
          "value": ""
        }
      ]
    },
    {
      "name": "rag-backend",
      "image": "adityaraj2104/rag-backend:latest",
      "essential": true,
      "memory": 512,
      "restartPolicy": {
        "name": "always"
      },
      "environment": [
        {
          "name": "GROQ_API_KEY",
          "value": ""
        },
        {
          "name": "MONGODB_URL",
          "value": ""
        },
        {
          "name": "DATABASE_NAME",
          "value": ""
        }
      ]
    },
    {
      "name": "healthcare-frontend",
      "image": "adityaraj2104/healthcare-frontend:latest",
      "essential": true,
      "memory": 256,
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80
        }
      ],
      "restartPolicy": {
        "name": "always"
      },
      "links": [
        "healthcare-backend",
        "rag-backend"
      ]
    }
  ]
}
